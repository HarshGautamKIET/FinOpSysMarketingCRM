# Copy this file to .env and fill in your Supabase credentials
#
# Option A - Supabase Cloud:
#   Get these from: https://supabase.com/dashboard -> Project Settings -> API
#
# Option B - Local Docker (self-hosted):
#   1. cd supabase && docker compose up -d
#   2. Studio: http://localhost:8000  (supabase / see supabase/.env DASHBOARD_PASSWORD)
#   3. Use the values below for local development:

VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=your-anon-key-here
